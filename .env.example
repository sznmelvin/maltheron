# Maltheron Environment Variables

# Convex - Your deployed Convex backend
CONVEX_URL=https://your-convex-deployment.convex.cloud
VITE_CONVEX_URL=https://your-convex-deployment.convex.cloud

# Environment
NODE_ENV=development
LOG_LEVEL=debug

# Security - Production Settings
# NODE_ENV=production
# LOG_LEVEL=info
# ALLOWED_ORIGINS=https://your-domain.com

# Development token for /v1/auth/dev/create endpoint
DEV_TOKEN=your-dev-secret-token
VITE_DEV_TOKEN=your-dev-secret-token

# Solana Configuration
# REQUIRED: Treasury wallet address for fee collection (0.1% of each transaction)
TREASURY_WALLET=SoLanaAddrHere11111111111111111111111111111111111111111

# Optional: Custom Solana RPC (defaults to mainnet-beta)
# RPC_URL=https://api.mainnet-beta.solana.com
# For production, use Helius or QuickNode for better reliability
# RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY

SENTRY_DSN=https://your-sentry-dsn@o123456.ingest.sentry.io/1234567
SENTRY_ENVIRONMENT=production
